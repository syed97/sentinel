# Sentinel Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub

# ── Database ────────────────────────────────────────────────────────────────
# Local dev: set automatically by Docker Compose
# Railway: set automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql://sentinel:sentinel_dev@localhost:5432/sentinel

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-64-char-string

# ── Web Push / VAPID ────────────────────────────────────────────────────────
# Generate with: python scripts/generate_vapid.py (see README)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=your-email@domain.com

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
